{
  "name": "instanssi-admin",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.1",
  "pnpm": {
    "onlyBuiltDependencies": [],
    "onlyBuiltDependenciesFile": "",
    "blockExoticSubdeps": false,
    "minimumReleaseAge": "1440"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build --emptyOutDir",
    "build:production": "vite build -l error",
    "preview": "vite preview",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint src/ --fix",
    "format": "prettier --write vite.config.ts vitest.config.ts env.d.ts src/**/*.ts src/**/*.vue",
    "lint-check": "eslint src/",
    "format-check": "prettier -c vite.config.ts vitest.config.ts env.d.ts src/**/*.ts src/**/*.vue",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fontsource/exo-2": "^5.2.8",
    "@fontsource/fira-mono": "^5.2.7",
    "@fontsource/open-sans": "^5.2.7",
    "@formkit/drag-and-drop": "^0.5.3",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/vue-fontawesome": "^3.2.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@instanssi/api": "file:../shared/api",
    "@sentry/vue": "^10.52.0",
    "chart.js": "^4.5.1",
    "lodash-es": "^4.18.1",
    "pdf-lib": "^1.17.1",
    "temporal-polyfill": "^0.3.2",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.34",
    "vue-chartjs": "^5.3.3",
    "vue-i18n": "^11.4.2",
    "vue-router": "^4.6.4",
    "vue-toastification": "2.0.0-rc.5",
    "vuetify": "^3.12.5",
    "vuetify-pro-tiptap": "^2.8.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^9.33.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "sass-embedded": "^1.99.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.11",
    "vite-plugin-compression2": "^2.5.3",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8"
  }
}
